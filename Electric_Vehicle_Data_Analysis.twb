      </column>
      <column caption='Total BEV Vehical' datatype='integer' name='[Calculation_2330187309309955]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(&#13;&#10;IF [Electric Vehicle Type]=&quot;Battery Electric Vehicle (BEV)&quot;&#13;&#10;THEN [DOL Vehicle ID]&#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='% of BEV Vehicles' datatype='real' name='[Calculation_2330187310419972]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_2330187309309955]/ [Calculation_2330187300417537]' />
      </column>
      <column caption='TOTAL PHVE VEHICLES' datatype='integer' name='[Calculation_2330187314618373]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(&#13;&#10;IF [Electric Vehicle Type]= &quot;Plug-in Hybrid Electric Vehicle (PHEV)&quot;&#13;&#10;THEN [DOL Vehicle ID] &#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='% OF PHVE VEHICLES' datatype='real' name='[Calculation_2330187317514246]' role='measure' type='quantitative'>
